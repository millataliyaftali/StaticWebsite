body{
    margin:0;
    padding:0;
    font-family:Arial, sans-serif;
    background:#f4f4f4;
}

.container{
    width:80%;
    max-width:600px;
    margin:100px auto;
    text-align:center;
    background:white;
    padding:30px;
    border-radius:10px;
}

h1{
    color:#0078D4;
}

button{
    padding:10px 20px;
    border:none;
    border-radius:5px;
    cursor:pointer;
    font-size:16px;
}

button:hover{
    transform:scale(1.05);
}

#message{
    margin-top:20px;
    font-weight:bold;
}
